# Server port
PORT=3000

# Webhook auth mode:
# - bearer : always require Authorization: Bearer <token>
# - none   : no auth required
# - auto   : require token only if WEBHOOK_AUTH_TOKEN is set
WEBHOOK_AUTH_MODE=bearer

# Use a strong secret token when WEBHOOK_AUTH_MODE=bearer
WEBHOOK_AUTH_TOKEN=wdbgshbsb2323238987

# If you want NO auth, use:
# WEBHOOK_AUTH_MODE=none
# WEBHOOK_AUTH_TOKEN=
